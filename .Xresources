! ------------------------------------------------------------------------------
! ROFI Color theme
! ------------------------------------------------------------------------------
rofi.opacity: 90
rofi.font: Inconsolata, FontAwesome 13
! Use extended color scheme
rofi.color-enabled:                  true
! Color scheme for normal row
rofi.color-normal:                   #0e0d10, #dbe3da , #0e0d10 , #615f8a , #dbe3da
rofi.color-urgent:                   #0e0d10, #dbe3da , #0e0d10 , #7b686b , #dbe3da
! Color scheme for active row
rofi.color-active:                   #0e0d10, #dbe3da , #0e0d10 , #615f8a , #dbe3da
! Color scheme window
rofi.color-window:                   #0e0d10, #0e0d10 , #615f8a
! Separator style (none, dash, solid)
rofi.separator-style:                solid
! make otf / ttf fonts look pretty.  does not matter if you are using a bitmap font.

! special
*.foreground:   #dbe3da
*.background:   #0e0d10
*.cursorColor:  #dbe3da

! black
*.color0:       #0e0d10
*.color8:       #666666

! red
*.color1:       #7b686b
*.color9:       #7b686b

! green
*.color2:       #615f8a
*.color10:      #615f8a

! yellow
*.color3:       #965d91
*.color11:      #965d91

! blue
*.color4:       #70b19f
*.color12:      #70b19f

! magenta
*.color5:       #a0a2a6
*.color13:      #a0a2a6

! cyan
*.color6:       #acd4c3
*.color14:      #acd4c3

! white
*.color7:       #dbe3da
*.color15:      #dbe3da


