#!/bin/bash
# ~/.dmenurc
DMENU_FN="Roboto-10"
DMENU_NB="#ffffff"
DMENU_NF="#707070"
DMENU_SB="#a1d569"
DMENU_SF="#707070"
TERMINAL_CMD="roxterm"
PANEL_HEIGHT="25"
DMENU_OPTIONS=" -fn $DMENU_FN -nb $DMENU_NB -nf $DMENU_NF -sf $DMENU_SF -sb $DMENU_SB"
export DMENU_FN DMENU_NB DMENU_NF DMENU_SF DMENU_SB DMENU_OPTIONS PANEL_HEIGHT
